# ============================================================
# Price Arbitrage — 環境変数設定
# ============================================================
# このファイルを .env にコピーして値を設定してください：
#   copy .env.example .env
# ============================================================

# ---- eBay Browse API（無料 5,000回/日）----
# https://developer.ebay.com/ でアカウント作成後
# Application Keys ページで Production Keyset を生成
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret

# ---- 楽天市場API ----
# https://webservice.rakuten.co.jp/ でアプリ登録
RAKUTEN_APP_ID=your_rakuten_app_id

# ---- サーバー設定 ----
PORT=3000

# ---- デモモード（APIキー不要でサンプルデータ表示）----
# DEMO_MODE=true
